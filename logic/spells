from logic.damage import DamageType

class Spell:
    def __init__(self, name, damage: DamageType, ap_cost, tag="int", ranged=None):
        self.name = name
        self.damage = damage
        self.ap_cost = ap_cost
        self.tag = tag
        self.ranged = ranged

    def __str__(self):
        return f"{self.name} (Spell, Damage: {self.damage})"

    def describe(self):
        return (
            f"{self.name} is a spell that deals {self.damage} damage."
        )

class Firebolt(Spell):
    def __init__(self, name, damage: DamageType, ap_cost, tag="int", ranged=True):
        super().__init__(name, damage, ap_cost, tag, ranged)
        self.damage = DamageType(fire = 12)
        ap_cost = 2
    def __str__(self):
        return f"{self.name} (Spell, Damage: {self.damage})"

    def describe(self):
        return (
            f"{self.name} is a basic fire spell "
            f"It deals {self.damage} damage from a distance."
        )
    
